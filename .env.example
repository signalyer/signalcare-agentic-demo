# Copy to .env and fill in real values.
# The .env file is gitignored.

# ---------- LLM Providers ----------
# For Reasoning/Balanced tiers via OpenRouter (routes to Claude/GPT/Gemini)
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_REASONING_MODEL=anthropic/claude-opus-4-7
OPENROUTER_BALANCED_MODEL=anthropic/claude-sonnet-4-6
OPENROUTER_FAST_MODEL=anthropic/claude-haiku-4-5

# Anthropic direct (optional; used if BAA path is direct)
ANTHROPIC_API_KEY=

# Ollama for local Fast tier (defaults; only set to override)
OLLAMA_HOST=http://ollama:11434
OLLAMA_FAST_MODEL=llama3.2:3b
OLLAMA_BALANCED_MODEL=qwen2.5:14b

# ---------- Adapters ----------
POSTGRES_PASSWORD=devpass
POSTGRES_URL=postgresql://sc:devpass@postgres:5432/signalcare

MINIO_ROOT_USER=scadmin
MINIO_ROOT_PASSWORD=devpassword
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=signalcare-evidence

NATS_URL=nats://nats:4222

VAULT_ADDR=http://vault:8200
VAULT_DEV_TOKEN=devroot

KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=signalcare
KEYCLOAK_CLIENT_ID=signalcare-app

# ---------- Observability ----------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=signalcare-app
GRAFANA_PASSWORD=devpass

# ---------- Guardrails ----------
# Set to true to enforce BAA gate (block PHI-bearing calls to unapproved endpoints)
REQUIRE_BAA=false
# Vendors approved to receive PHI (comma-separated)
APPROVED_PHI_VENDORS=

# ---------- Feature Flags ----------
AGENTS_COMPLIANCE_OPS=true
AGENTS_PROVIDER_INTAKE=true
AGENTS_DOCUMENT_EXTRACTION=true
AGENTS_RECONCILIATION=true
AGENTS_CLINICAL_SUMMARY=true

# ---------- Demo Data ----------
SEED_SYNTHETIC_DATA=true
