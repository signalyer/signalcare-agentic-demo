# Copy to .env and fill in real values.
# The .env file is gitignored.

# ---------- LLM Providers ----------
# Hosted tier: Anthropic direct SDK (see ADR-0004).
# Reasoning -> claude-opus-*, Balanced -> claude-sonnet-*.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_REASONING_MODEL=claude-opus-4-7
ANTHROPIC_BALANCED_MODEL=claude-sonnet-4-6

# OpenAI direct key. Not currently used by any adapter -- reserved for a future
# openai_gateway.py sibling if Phase 7's adversarial-verify needs a second diverse
# hosted provider. Safe to leave blank until then.
OPENAI_API_KEY=

# Ollama for local Fast tier.
# Weeks 1-2 native install per ADR-0003: use http://localhost:11434 .
# Phase 3+ (docker-compose stack): use http://ollama:11434 .
OLLAMA_HOST=http://localhost:11434
OLLAMA_FAST_MODEL=llama3.2:3b
OLLAMA_BALANCED_MODEL=qwen2.5:14b

# ---------- Adapters ----------
# Docker-service hostnames below are for the Phase 3 docker-compose stack (ADR-0003).
# Override to `localhost` when running any of these natively.
POSTGRES_PASSWORD=devpass
POSTGRES_URL=postgresql://sc:devpass@postgres:5432/signalcare

MINIO_ROOT_USER=scadmin
MINIO_ROOT_PASSWORD=devpassword
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=signalcare-evidence

NATS_URL=nats://nats:4222

VAULT_ADDR=http://vault:8200
VAULT_DEV_TOKEN=devroot

KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=signalcare
KEYCLOAK_CLIENT_ID=signalcare-app

# ---------- Observability ----------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=signalcare-app
GRAFANA_PASSWORD=devpass

# ---------- Guardrails ----------
# BAA gate (L2 middleware, ADR-0005). When true, requests tagged phi_present=True
# are checked against APPROVED_PHI_VENDORS before dispatch; unapproved vendors
# return HTTP 451. Non-PHI calls flow freely (ADR-0006).
# Default true per CLAUDE.md rule 3 ("BAA gate is real middleware. No exceptions.")
REQUIRE_BAA=true
# Vendors approved to receive PHI (comma-separated, case-insensitive).
# Matches against each concrete adapter's `provider_name` — currently `anthropic`
# (BAA-eligible in production) and `ollama` (local; no data leaves the process).
APPROVED_PHI_VENDORS=anthropic,ollama

# PHI redactor (L2 middleware, ADR-0006). Scans outgoing message content for
# T1-T4 PHI, sets phi_present + phi_tier on the request that the BAA gate reads.
#   strict   — redact T1 (SSN/MRN/CC) and T2 (email/phone/DOB/address) to tokens
#   standard — redact T1 only; T2 tagged but content passed through
#   off      — detect + tag only; no content mutation
REDACTION_MODE=strict

# Injection sentinel (L2 middleware, ADR-0007). Outermost guardrail — runs
# BEFORE the redactor. Regex-first detection against known-injection patterns;
# on regex miss + suspicion-keyword hit, calls the Fast-tier LLM classifier.
# Fail-open on classifier error (regex-only fallback).
#   block — raise InjectionSentinelError → HTTP 400 on detection (default)
#   flag  — log WARN with source + pattern, forward request untouched
#   off   — skip detection entirely
SENTINEL_MODE=block
# Confidence threshold above which the LLM classifier verdict flips detection
# to true. Float in [0.0, 1.0].
SENTINEL_LLM_THRESHOLD=0.7

# ---------- Feature Flags ----------
AGENTS_COMPLIANCE_OPS=true
AGENTS_PROVIDER_INTAKE=true
AGENTS_DOCUMENT_EXTRACTION=true
AGENTS_RECONCILIATION=true
AGENTS_CLINICAL_SUMMARY=true

# ---------- Demo Data ----------
SEED_SYNTHETIC_DATA=true
